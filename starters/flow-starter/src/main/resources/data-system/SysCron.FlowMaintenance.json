{
  "SysCron": [
    {
      "id": "flow_approval_timeout_remind",
      "name": "flow_approval_timeout_remind",
      "cronExpression": "0 */5 * * * ?",
      "cronSemantic": "Every 5 minutes",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Send approval timeout reminder notifications"
    },
    {
      "id": "flow_approval_timeout_handle",
      "name": "flow_approval_timeout_handle",
      "cronExpression": "0 */10 * * * ?",
      "cronSemantic": "Every 10 minutes",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Handle timed-out approval tasks (auto-approve/reject/escalate)"
    },
    {
      "id": "flow_delegation_expiry",
      "name": "flow_delegation_expiry",
      "cronExpression": "0 0 * * * ?",
      "cronSemantic": "Every hour",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Expire delegation rules past their end time"
    },
    {
      "id": "flow_timer_sweep",
      "name": "flow_timer_sweep",
      "cronExpression": "0 */5 * * * ?",
      "cronSemantic": "Every 5 minutes",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Resume WAITING instances with a due timer missed by Pulsar deliverAfter"
    },
    {
      "id": "flow_instance_stuck_scan",
      "name": "flow_instance_stuck_scan",
      "cronExpression": "0 0 */1 * * ?",
      "cronSemantic": "Every hour",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Log non-terminal instances with no recent updates for operator review"
    },
    {
      "id": "flow_debug_bundle_purge",
      "name": "flow_debug_bundle_purge",
      "cronExpression": "0 0 2 * * ?",
      "cronSemantic": "Every day at 02:00",
      "limitExecution": false,
      "tenantJobMode": "CROSS_TENANT",
      "active": false,
      "description": "Purge expired debug-run bundles with their instances, traces and approval projections"
    }
  ]
}
